---
import { getLangFromUrl, useTranslations } from "../utils/i18n";
export interface Props {
  title?: string;
  highlightColor?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title = t("whoami.title"), highlightColor = "text-pink-400" } =
  Astro.props;

// Reemplazamos la variable en el string para mantener tu clase CSS dinámica
const p2 = t("whoami.p2").replace(/{highlightColor}/g, highlightColor);
---

<section class="max-w-2xl mx-auto px-4 py-8">
  <h2
    class={`text-2xl font-bold ${highlightColor} mb-6 border-b border-pink-500 pb-2`}
  >
    {title}
  </h2>

  <div class="space-y-4 text-gray-300">
    <p set:html={t("whoami.p1")} />
    <p set:html={p2} />
    <p set:html={t("whoami.p3")} />
    <p class="pt-4 italic text-gray-400" set:html={t("whoami.p4")} />
  </div>
</section>
