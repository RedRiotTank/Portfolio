---
import LanguagePicker from "./LanguagePicker.astro";
import {
  getLangFromUrl,
  useTranslations,
  translatePath,
} from "../../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header>
  <nav x-data="{ open: false }" class="py-6 px-8 max-w-7xl mx-auto">
    <div class="flex justify-between items-center">
      <!-- Izquierda: Logo -->
      <div class="flex items-center gap-3">
        <a href={translatePath("/", lang)} class="flex items-center gap-3">
          <img
            src="/images/Profile_pic.jpg"
            alt="Alberto's profile pic"
            class="w-10 h-10 rounded-full object-cover"
          />
          <span class="text-white font-semibold text-lg">Alberto</span>
        </a>
      </div>

      <!-- Derecha: Navegación + Idioma + Hamburguesa -->
      <div class="flex items-center gap-4 sm:gap-6">
        <!-- Menú Desktop -->
        <ul
          class="hidden md:flex gap-8 text-sm font-medium text-white items-center"
        >
          <li>
            <a
              href={translatePath("/", lang)}
              class="group flex flex-col items-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="text-pink-500 w-5 h-5 group-hover:text-white transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
                <path d="M9 22V12h6v10"></path>
              </svg>
              <span
                class="uppercase tracking-widest relative group-hover:text-white mt-1"
              >
                {t("nav.home")}
                <span
                  class="absolute left-0 -bottom-1 w-full h-0.5 bg-purple-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
                ></span>
              </span>
            </a>
          </li>
          <li>
            <a
              href={translatePath("/projects", lang)}
              class="group flex flex-col items-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-pink-500 group-hover:text-white transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
              <span
                class="uppercase tracking-widest relative group-hover:text-white mt-1"
              >
                {t("nav.projects")}
                <span
                  class="absolute left-0 -bottom-1 w-full h-0.5 bg-purple-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
                ></span>
              </span>
            </a>
          </li>
          <li>
            <a
              href={translatePath("/about", lang)}
              class="group flex flex-col items-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-pink-500 group-hover:text-white transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M20 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M4 21v-2a4 4 0 0 1 3-3.87"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span
                class="uppercase tracking-widest relative group-hover:text-white mt-1"
              >
                {t("nav.about")}
                <span
                  class="absolute left-0 -bottom-1 w-full h-0.5 bg-purple-500 scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
                ></span>
              </span>
            </a>
          </li>
        </ul>

        <!-- Language Picker (Visible siempre) -->
        <LanguagePicker />

        <!-- Botón Hamburguesa -->
        <button
          @click="open = !open"
          class="md:hidden text-white focus:outline-none"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              x-show="!open"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
            <path
              x-show="open"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Menú Mobile -->
    <div x-show="open" x-transition class="md:hidden mt-4 space-y-4">
      <a
        href={translatePath("/", lang)}
        class="flex items-center gap-2 text-white text-sm font-medium"
      >
        <!-- (Mismos SVGs del mobile menu original omitidos por brevedad) -->
        {t("nav.home")}
      </a>
      <a
        href={translatePath("/projects", lang)}
        class="flex items-center gap-2 text-white text-sm font-medium"
      >
        {t("nav.projects")}
      </a>
      <a
        href={translatePath("/about", lang)}
        class="flex items-center gap-2 text-white text-sm font-medium"
      >
        {t("nav.about")}
      </a>
    </div>
  </nav>
</header>
