---
import { getLangFromUrl, useTranslations } from "../utils/i18n";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="w-full px-4">
  <h2 class="text-white text-3xl font-bold mb-6 text-center">
    {t("resume.title")}
  </h2>

  <a
    href="/documents/AlbertoResume.pdf"
    target="_blank"
    class="group relative block w-full max-w-3xl mx-auto rounded-xl overflow-hidden shadow-lg"
  >
    <div class="relative overflow-hidden rounded-xl" style="height: 300px;">
      <img
        src="/images/CV_preview.png"
        alt={t("resume.title")}
        class="w-full h-[400px] object-cover object-[50%_top] transition-all duration-500 group-hover:translate-y-[-100px]"
      />
      <div
        class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/60 to-transparent px-4 py-3"
      >
        <div class="text-white text-lg font-semibold text-center">
          {t("resume.click")}
        </div>
      </div>
    </div>
  </a>
</section>
