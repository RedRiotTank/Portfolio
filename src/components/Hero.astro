---
import Contact from "./Contact.astro";
import FeaturedProjects from "./FeaturedProjects.astro";
import Pheader from "./common/Pheader.astro";
import Resume from "./Resume.astro";
import TechStack from "./TechStack.astro";
import { getLangFromUrl, useTranslations, translatePath } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-5 text-center md:text-left">
  <Pheader text={t("hero.greeting")} align="left" />
  <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6">
    {t("hero.title1")}
    <br class="hidden sm:block" />
    {t("hero.title2")}
  </h1>

  <p class="text-xl text-gray-300 max-w-2xl md:mx-0">
    {t("hero.desc")}
  </p>

  <div
    class="mt-8 flex flex-row flex-wrap gap-4 justify-center md:justify-start items-center"
  >
    <a
      href="#contact"
      class="bg-pink-600 hover:bg-pink-700 text-white px-6 py-3 rounded-lg font-medium transition whitespace-nowrap"
    >
      {t("hero.btn.contact")}
    </a>
    <a
      href={translatePath("/projects", lang)}
      class="border border-gray-600 hover:border-pink-500 text-gray-300 px-6 py-3 rounded-lg font-medium transition whitespace-nowrap"
    >
      {t("hero.btn.work")}
    </a>
  </div>
</section>

<section
  class="flex flex-col xl:flex-row gap-8 mt-16 items-center xl:items-start justify-between"
>
  <div class="w-full xl:w-[48%]">
    <Resume />
  </div>
  <div>
    <Contact />
  </div>
</section>

<FeaturedProjects limit={3} />

<TechStack />
