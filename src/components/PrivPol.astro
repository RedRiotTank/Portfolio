---
import Pheader from "../components/common/Pheader.astro";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="max-w-4xl mx-auto px-6 py-12 text-gray-300">
  <Pheader text={t("privpol.title")} align="center" />

  <div class="prose prose-invert max-w-none">
    <p class="text-pink-500 text-sm mb-8">{t("privpol.updated")}</p>

    <div class="bg-gray-800/50 p-6 rounded-xl mb-8 border border-gray-700">
      <p class="text-lg">
        {t("privpol.intro")}
      </p>
    </div>

    <div class="space-y-8">
      <!-- Interpretation and Definitions -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.terms.title")}
        </h2>

        <ul class="list-disc pl-6 space-y-2">
          <li>
            <strong>Portfolio</strong>
            {t("privpol.terms.portfolio").replace("Portfolio ", "")}
          </li>
          <li>
            <strong>I/Me/My</strong>
            {t("privpol.terms.me").replace("I/Me/My ", "")}
          </li>
          <li>
            <strong>You/Your</strong>
            {t("privpol.terms.you").replace("You/Your ", "")}
          </li>
          <li>
            <strong>Demo Applications</strong>
            {t("privpol.terms.demos").replace("Demo Applications ", "")}
          </li>
          <li>
            <strong>Cookies</strong>
            {t("privpol.terms.cookies").replace("Cookies ", "")}
          </li>
        </ul>
      </div>

      <!-- Data Collection -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.collection.title")}
        </h2>

        <div class="bg-gray-800/30 p-4 rounded-lg mb-4">
          <h4 class="font-medium text-white">{t("privpol.collection.what")}</h4>
          <p>{t("privpol.collection.desc")}</p>
          <ul class="list-disc pl-6 mt-2 space-y-1">
            <li>
              <strong>{t("privpol.collection.vol").split(":")[0]}:</strong>
              {t("privpol.collection.vol").split(":")[1]}
            </li>
            <li>
              <strong>{t("privpol.collection.auto").split(":")[0]}:</strong>
              {t("privpol.collection.auto").split(":")[1]}
            </li>
            <li>
              <strong>{t("privpol.collection.cook").split(":")[0]}:</strong>
              {t("privpol.collection.cook").split(":")[1]}
            </li>
          </ul>
        </div>

        <div class="bg-gray-800/30 p-4 rounded-lg">
          <h4 class="font-medium text-white">{t("privpol.tracking.title")}</h4>
          <p>{t("privpol.tracking.desc")}</p>
          <div class="mt-3 grid sm:grid-cols-2 gap-4">
            <div class="bg-gray-900/50 p-3 rounded">
              <p class="text-pink-500 text-sm">
                {t("privpol.tracking.c1.title")}
              </p>
              <p class="text-sm">{t("privpol.tracking.c1.desc")}</p>
            </div>
            <div class="bg-gray-900/50 p-3 rounded">
              <p class="text-pink-500 text-sm">
                {t("privpol.tracking.c2.title")}
              </p>
              <p class="text-sm">{t("privpol.tracking.c2.desc")}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- How I Use Data -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.use.title")}
        </h2>
        <p>{t("privpol.use.desc")}</p>

        <ul class="list-disc pl-6 space-y-2 mt-3">
          <li>
            <strong>{t("privpol.use.f1").split(":")[0]}:</strong>
            {t("privpol.use.f1").split(":")[1]}
          </li>
          <li>
            <strong>{t("privpol.use.f2").split(":")[0]}:</strong>
            {t("privpol.use.f2").split(":")[1]}
          </li>
          <li>
            <strong>{t("privpol.use.f3").split(":")[0]}:</strong>
            {t("privpol.use.f3").split(":")[1]}
          </li>
        </ul>

        <div class="mt-4 bg-gray-800/20 p-4 rounded border border-gray-700">
          <p class="text-sm">
            <span class="text-pink-400 font-medium"
              >{t("privpol.use.important").split(":")[0]}:</span
            >
            {t("privpol.use.important").split(":")[1]}
          </p>
        </div>
      </div>

      <!-- Data Protection -->
      <div class="bg-gray-800/50 p-6 rounded-xl border border-gray-700">
        <h3 class="text-xl font-semibold text-white mb-3">
          {t("privpol.security.title")}
        </h3>
        <p>{t("privpol.security.desc")}</p>
        <ul class="list-disc pl-6 mt-2 space-y-1">
          <li>{t("privpol.security.s1")}</li>
          <li>{t("privpol.security.s2")}</li>
          <li>{t("privpol.security.s3")}</li>
        </ul>
        <p class="mt-3 text-sm">
          {t("privpol.security.note")}
          <a
            href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement"
            class="text-pink-400 hover:text-pink-300"
            target="_blank">{t("privpol.security.link")}</a
          >.
        </p>
      </div>

      <!-- Third Parties -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.third.title")}
        </h2>
        <p>{t("privpol.third.desc")}</p>
        <ul class="list-disc pl-6 mt-2 space-y-1">
          <li>{t("privpol.third.t1")}</li>
          <li>{t("privpol.third.t2")}</li>
          <li>{t("privpol.third.t3")}</li>
        </ul>
        <p class="mt-3">{t("privpol.third.end")}</p>
      </div>

      <!-- Your Rights -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.rights.title")}
        </h2>
        <p>{t("privpol.rights.desc")}</p>
        <ul class="list-disc pl-6 mt-2 space-y-1">
          <li>{t("privpol.rights.r1")}</li>
          <li>{t("privpol.rights.r2")}</li>
          <li>{t("privpol.rights.r3")}</li>
        </ul>
      </div>

      <!-- Changes to Policy -->
      <div>
        <h2
          class="text-2xl font-bold text-white mb-4 border-b border-gray-700 pb-2"
        >
          {t("privpol.updates.title")}
        </h2>
        <p>{t("privpol.updates.desc")}</p>
      </div>

      <!-- Contact -->
      <div class="bg-pink-900/20 p-6 rounded-xl border border-pink-900/50">
        <h2 class="text-2xl font-bold text-white mb-4">
          {t("privpol.contact.title")}
        </h2>
        <p>{t("privpol.contact.desc")}</p>
        <ul class="list-disc pl-6 mt-2">
          <li>
            {t("privpol.contact.email")}
            <a
              href="mailto:albertoplazamontesdm@gmail.com"
              class="text-pink-400 hover:text-pink-300"
              >albertoplazamontesdm@gmail.com</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
